VERA_SECRET_KEY=your-64-character-random-secret-key-here
VERA_DEBUG=false
VERA_ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://vera_user:your_password@localhost:5432/vera_db
POSTGRES_USER=vera_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=vera_db

REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

OPENAI_API_KEY=sk-your-openai-key-here-optional
GOOGLE_API_KEY=your-google-key-here-optional

TEXT_EMBED_MODEL=nomic-ai/nomic-embed-text-v1
NLI_MODEL=cross-encoder/nli-deberta-v3-small
CLIP_MODEL=openai/clip-vit-base-patch32

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_CONCURRENCY=1

MAX_UPLOAD_SIZE_MB=50
ALLOWED_ORIGINS=http://localhost:3000
